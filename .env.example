# 部署前端（Vercel / Zeabur）— 由 server.js 注入 /runtime-config.js
SUPABASE_URL=https://your-zeabur-supabase-host
SUPABASE_ANON_KEY=your-anon-key
# 官方 Supabase 用 public；Zeabur 共用實例用 mp_checklist
SUPABASE_DB_SCHEMA=mp_checklist

# 資料 migration（.\supabase\scripts\run-migration.ps1）— 勿 commit 實際密碼
#
# SOURCE_DB：官方 Direct connection（db.*.supabase.co）若本機無 IPv6 會連不上，
#   請改 Dashboard → Connect → Session pooler（IPv4，port 5432 或 6543）。
# TARGET_DB：必須用 Zeabur「Postgres」服務的 External/Public 主機，
#   不可使用 SUPABASE_URL（例如 jerrysupabase.zeabur.app 是 API，port 5432 通常會拒絕）。
# SOURCE_DB=postgresql://postgres.iotjuquhpqctgsnetmnc:[PASSWORD]@db.iotjuquhpqctgsnetmnc.supabase.co:5432/postgres
# 方式 A：完整 URI
# TARGET_DB=postgresql://postgres:[PASSWORD]@[IP]:[外部埠]/postgres
#
# 方式 B：分拆（密碼含特殊字元時較不易出錯，run-migration 會自動組 URI）
# TARGET_PG_HOST=8.213.234.32
# TARGET_PG_PORT=30206
# TARGET_PG_USER=postgres
# TARGET_PG_PASSWORD=從 Zeabur Postgres 服務的 POSTGRES_PASSWORD 複製
# TARGET_PG_DATABASE=postgres
#
# 密碼來源：Zeabur「Postgres / PostgreSQL」服務 → POSTGRES_PASSWORD
# 不是：Supabase 服務的 anon key、JWT_SECRET、SERVICE_ROLE_KEY
# 測試：.\supabase\scripts\test-target-db.ps1
